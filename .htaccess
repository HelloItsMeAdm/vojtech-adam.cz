<IfModule mod_headers.c>
  Header set Content-Security-Policy "upgrade-insecure-requests;"
  Header unset Permissions-Policy
  Header always set Permissions-Policy "accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
</IfModule>

# Cache: statické assety (JS/CSS/obrázky) na 1 rok, HTML bez cache
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

RewriteEngine On


# Redirect /playstore to Google Play
RewriteRule ^playstore$ https://play.google.com/store/apps/dev?id=6507096780312923677 [R=301,L]

# Subdomains → /sub/<subdomain>/ (e.g. rolety.vojtech-adam.cz → /sub/rolety/)
RewriteCond %{HTTP_HOST} ^([a-z0-9-]+)\.vojtech-adam\.cz$ [NC]
RewriteCond %1 !^(www)$ [NC]
RewriteCond %{REQUEST_URI} !^/sub/ [NC]
RewriteCond %{DOCUMENT_ROOT}/sub/%1/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/sub/%1/$1 -d
RewriteRule ^(.*)$ /sub/%1/$1 [L]

# Subdomain SPA fallback
RewriteCond %{HTTP_HOST} ^([a-z0-9-]+)\.vojtech-adam\.cz$ [NC]
RewriteCond %1 !^(www)$ [NC]
RewriteCond %{REQUEST_URI} !^/sub/ [NC]
RewriteCond %{DOCUMENT_ROOT}/sub/%1 -d
RewriteRule ^.*$ /sub/%1/index.html [L]

# SPA fallback — only for main domain, route non-file/non-dir requests to index.html
RewriteCond %{HTTP_HOST} ^(www\.)?vojtech-adam\.cz$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]